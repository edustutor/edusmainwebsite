# AWS SES SMTP — used by /api/contact route
# Create SMTP credentials in AWS SES console:
#   https://console.aws.amazon.com/ses/home#/smtp
# Choose the same AWS region your sender domain is verified in.

SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Sender — must be a verified address (or use a verified domain) in AWS SES
CONTACT_FROM_EMAIL=no-replay@edus.edu.lk
CONTACT_FROM_NAME=EDUS Inquiries

# Where contact-form submissions get delivered
CONTACT_TO_EMAIL=sugeevanit@gmail.com

# ---------------------------------------------------------------
# Cloudinary — powers the /gallery pages + the fetch script
# Find these at https://console.cloudinary.com/console -> Account Details
# Server-only secrets are read by scripts/fetch-cloudinary-gallery.mjs;
# NEXT_PUBLIC_CLOUDINARY_CLOUD is shipped to the browser by next/image.
# ---------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
NEXT_PUBLIC_CLOUDINARY_CLOUD=
# CLOUDINARY_GALLERY_FOLDER=edus-gallery

# ---------------------------------------------------------------
# Google Places API (New) - powers live Google reviews on /sl.
# Server-only - never prefix NEXT_PUBLIC_.
# Find values at https://console.cloud.google.com/apis/credentials
# ---------------------------------------------------------------
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACES_PLACE_ID=

# ---------------------------------------------------------------
# EDUS Admissions Chatbot - NVIDIA NIM (OpenAI-compatible).
# Server-only - the key never reaches the browser.
# Generate at https://build.nvidia.com -> API Keys.
# NVIDIA_MODEL is optional; defaults to meta/llama-3.3-70b-instruct
# inside app/api/chat/route.ts if unset.
# ---------------------------------------------------------------
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# Tavily Search API - powers the chatbot's site-restricted search tool.
# Free tier 1000 searches/mo. Sign up at https://tavily.com.
# Server-only: never expose to the browser.
TAVILY_API_KEY=

# Captured leads (parent name + phone + country + grade + medium +
# subject) get POSTed to this URL with header X-Source: edustutor-chatbot.
# If unset, leads are logged server-side only - never lost.
NEXT_PUBLIC_LEAD_ENDPOINT=
